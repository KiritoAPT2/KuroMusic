# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/

# Gradle files
.gradle/
build/

# Local configuration file (sdk.dir is not checked in)
local.properties

# Proguard folder generated by Android Studio
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ
*.iml
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/assetWizardSettings.xml
.idea/dictionaries
.idea/libraries
.idea/caches
.idea/modules.xml
.idea/runConfigurations.xml
.idea/navEditor.xml

# Keystore files
*.jks
*.keystore
*.pem
*.p12
*.key

# External native build folder generated in Android Studio for Native C++ code
.cxx/

# Google Services (e.g. APIs key)
google-services.json

# External build folders
.externalNativeBuild/
node_modules/

# Init-specific
.DS_Store
Thumbs.db

# Security audit reports (may contain credentials)
SECURITY_AUDIT_*.md

# Antigravity artifacts
.gemini/
.antigravityignore

.idea/
app/schemas/
*.log
.kotlin/
!app/src/main/baseline-prof.txt
